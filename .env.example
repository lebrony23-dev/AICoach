# Garmin Connect Credentials
GARMIN_EMAIL=your_email@example.com
GARMIN_PASSWORD=your_secure_password

# Gemini LLM API Key
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: Model name (default: gemini-3.5-flash)
GEMINI_MODEL=gemini-3.5-flash

# Telegram Bot Credentials
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Race Configuration (AEST time, format: YYYY-MM-DD)
RACE_DATE=2026-07-06

# Database & Storage Options
DB_PATH=garmin_data.db
GARMIN_TOKEN_STORE=.garmin_tokens
BACKUP_DIR=backups

# Server Configuration (For Webhook mode on Fly.io)
# WEBHOOK_URL=https://your-app-name.fly.dev
PORT=8080
